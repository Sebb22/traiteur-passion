APP_NAME="Traiteur Passion"
APP_ENV=dev
APP_DEBUG=true
APP_URL=http://localhost:8080

DB_HOST=localhost
DB_NAME=traiteur
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

ADMIN_USER=admin
# Mot de passe: ChangeMe!2026 (à changer immédiatement)
ADMIN_PASSWORD_HASH=$2y$10$ksKrVZ8biqaJgEla5/wV.ez9z0utjv2cwp/9JClRlWM8OwXx2U0gG

# Rembg image cutout
# Laisser vide pour utiliser le CLI local .venv-rembg/bin/rembg
REMBG_SERVER_URL=
REMBG_SERVER_TIMEOUT=120
REMBG_MODELS_DIR=
REMBG_MAX_INPUT_SIZE=1600
REMBG_PREVIEW_MAX_INPUT_SIZE=512
REMBG_DEBUG_TIMING=0
REMBG_PREVIEW_MODEL=u2netp
REMBG_FINAL_MODEL=u2net

# Mail SMTP
MAIL_ENABLED=0
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SMTP_AUTH=1
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_TIMEOUT=15
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Traiteur Passion"
MAIL_ADMIN_TO=contact@traiteur-passion.fr
MAIL_NOTIFY_ADMIN=1
MAIL_ACK_CLIENT=1

# Avis Google / commentaires Facebook sur la page A propos
SOCIAL_REVIEWS_ENABLED=1
SOCIAL_REVIEWS_CACHE_TTL=21600
SOCIAL_REVIEWS_TIMEOUT=6
SOCIAL_REVIEWS_DISPLAY_LIMIT=6

# Google Places API (Place Details v1)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_REVIEWS_LINK="https://www.google.com/search?sca_esv=95c4599e20cb2333&sxsrf=ANbL-n4UoR9hWZxE_DJOyM6c_ZDOCjkuoA:1769787102684&q=Traiteur+passion+Avis&rflfq=1&num=20&stick=H4sIAAAAAAAAAONgkxIxNDa3MLS0tDAzNTcyNjU0NLM0Nd7AyPiKUTSkKDGzJLW0SKEgsbg4Mz9PwbEss3gRK3ZxAH98L6dLAAAA&rldimm=13781998657235116953&tbm=lcl&hl=fr-FR&sa=X&ved=2ahUKEwj4o9XcyrOSAxW1caQEHbmhH6QQ9fQKegQIUxAG&biw=1920&bih=941&dpr=1&aic=0#lkt=LocalPoiReviews"
GOOGLE_REVIEWS_LIMIT=3

# Facebook Graph API
# Utiliser un token de page avec permissions de lecture d'engagement.
FACEBOOK_GRAPH_VERSION=v22.0
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_URL="https://www.facebook.com/kevinbrien6/reviews"
FACEBOOK_POSTS_LIMIT=5
FACEBOOK_COMMENTS_LIMIT=5
