APP_NAME="Application"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.test

DB_HOST=127.0.0.1
DB_NAME=app_database
DB_USER=app_user
DB_PASS=change_me
DB_CHARSET=utf8mb4

ADMIN_USER=admin_user
# Exemple uniquement: generez votre propre hash avant mise en production
ADMIN_PASSWORD_HASH=$2y$10$Q0Q8b0klqZsV5GLf0YUxNe0U/5h4v8xg8L7p5p4XqP1O8jQm5QbQK

# Rembg image cutout
# Laisser vide pour utiliser le CLI local .venv-rembg/bin/rembg
REMBG_SERVER_URL=
REMBG_SERVER_TIMEOUT=120
REMBG_MODELS_DIR=
REMBG_MAX_INPUT_SIZE=1600
REMBG_PREVIEW_MAX_INPUT_SIZE=512
REMBG_DEBUG_TIMING=0
REMBG_PREVIEW_MODEL=u2netp
REMBG_FINAL_MODEL=u2net

# Mail SMTP
MAIL_ENABLED=0
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SMTP_AUTH=1
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_TIMEOUT=15
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Application"
MAIL_ADMIN_TO=admin@example.test
MAIL_NOTIFY_ADMIN=1
MAIL_ACK_CLIENT=1

# Avis Google / commentaires Facebook sur la page A propos
SOCIAL_REVIEWS_ENABLED=1
SOCIAL_REVIEWS_CACHE_TTL=21600
SOCIAL_REVIEWS_TIMEOUT=6
SOCIAL_REVIEWS_DISPLAY_LIMIT=6

# Google Places API (Place Details v1)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_REVIEWS_LINK="https://www.google.com/maps/place/your-business"
GOOGLE_REVIEWS_LIMIT=3

# Facebook Graph API
# Utiliser un token de page avec permissions de lecture d'engagement.
FACEBOOK_GRAPH_VERSION=v22.0
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_URL="https://www.facebook.com/your-page/reviews"
FACEBOOK_POSTS_LIMIT=5
FACEBOOK_COMMENTS_LIMIT=5
